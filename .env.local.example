# Supabase (criar em supabase.com → Project Settings → API)
DATABASE_URL=postgresql://postgres:[senha]@db.[projeto].supabase.co:5432/postgres

# Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# N8N (URL pública do seu N8N — ex: Railway, Render)
NEXT_PUBLIC_N8N_URL=https://seu-n8n.railway.app
NEXT_PUBLIC_N8N_PUBLIC_URL=https://seu-n8n.railway.app

# Auth
NEXTAUTH_SECRET=gere_uma_string_aleatoria_de_32_chars
NEXTAUTH_URL=https://ativa-chemical.vercel.app
